# Copy this file to .env and fill in your Azure App Registration values.
# Register your app at https://portal.azure.com → Azure Active Directory → App registrations.
# Required API permission: Microsoft Graph → Delegated → Calendars.ReadWrite

MICROSOFT_CLIENT_ID=your_client_id_here
MICROSOFT_CLIENT_SECRET=your_client_secret_here
MICROSOFT_TENANT_ID=your_tenant_id_here
